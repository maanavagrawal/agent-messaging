DATABASE_URL=sqlite:///./fixlog.sqlite3
FIXLOG_PUBLIC_URL=http://localhost:8000
FIXLOG_ACCOUNT_1_TOKEN=replace-with-long-random-token-one
FIXLOG_ACCOUNT_1_NAME=Ada
FIXLOG_ACCOUNT_2_TOKEN=replace-with-long-random-token-two
FIXLOG_ACCOUNT_2_NAME=Grace
FIXLOG_AUTH_REQUIRED=false
FIXLOG_WEB_SECRET_KEY=replace-with-long-random-cookie-signing-secret
FIXLOG_WEB_COOKIE_SECURE=false
FIXLOG_WEB_SESSION_TTL_SECONDS=604800
FIXLOG_COLLECTOR_PACKAGE_URL=git+https://github.com/maanavagrawal/agent-messaging.git@main
FIXLOG_BASE_URL=http://localhost:8000
FIXLOG_API_TOKEN=replace-with-long-random-token-one
FIXLOG_CONFIG_PATH=/Users/you/.fixlog/config.toml
FIXLOG_HARNESS_MODEL_NAME=claude-code
FIXLOG_HARNESS_NAME=claude-code-log-watcher
FIXLOG_CLAUDE_PROJECTS_DIR=/Users/you/.claude/projects
FIXLOG_ALLOWED_PROJECTS=[]
FIXLOG_SESSION_MAP_PATH=/Users/you/.fixlog/session_map.json
FIXLOG_PENDING_HARVEST_DIR=/Users/you/.fixlog/pending_harvests
ANTHROPIC_API_KEY=replace-with-anthropic-api-key-for-harvests
FIXLOG_ANTHROPIC_MODEL=claude-sonnet-4-5
FIXLOG_AUTO_SUBMIT_HARVESTS=false
FIXLOG_SESSION_QUIET_SECONDS=300
FIXLOG_RECENT_SESSION_SECONDS=600
FIXLOG_SANDBOX_ALLOWED_IMAGES=python:3.11-slim,python:3.12-slim,node:20-slim,node:22-slim
FIXLOG_SANDBOX_QUEUE_SIZE=100
FIXLOG_SANDBOX_TIMEOUT_S=60
FIXLOG_SANDBOX_MEMORY_MB=512
FIXLOG_VERIFIER_ENABLED=true
